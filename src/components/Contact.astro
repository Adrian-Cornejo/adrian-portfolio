---
import {
  Mail,
  Phone,
  MapPin,
  MessageCircle,
  Linkedin,
  Github,
  User,
  ExternalLink,
} from "lucide-astro";
import Card from "./ui/Card.astro";
import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";
---

<!-- src/components/Contact.astro -->
<section id="contact" class="py-20 bg-surface">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-ink mb-6">
        Contacto
      </h2>
      <p class="text-lg text-ink-dim max-w-2xl mx-auto">
        Especializado en <strong class="text-ink">Angular</strong>, <strong
          class="text-ink">landing pages</strong
        > y
        <strong class="text-ink">aplicaciones web modernas</strong>. Conectemos
        para discutir tu proyecto.
      </p>
    </div>

    <!-- Contact Information -->
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Methods -->
        <div class="space-y-6">
          <Card padding="lg">
            <div class="flex items-center mb-6">
              <div
                class="w-10 h-10 bg-ink flex items-center justify-center mr-3"
              >
                <User class="w-5 h-5 text-bg" />
              </div>
              <h3 class="text-xl font-semibold text-ink">
                Información de Contacto
              </h3>
            </div>

            <!-- Contact Methods -->
            <div class="space-y-4">
              <!-- Email -->
              <a
                href="mailto:adrian.cornejo0105@gmail.com"
                class="flex items-center p-4 border border-border hover:border-accent transition-colors group no-underline"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 bg-accent/10 flex items-center justify-center"
                >
                  <Mail class="w-6 h-6 text-accent" />
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-ink">Email</h4>
                  <p class="text-sm text-ink-dim">
                    adrian.cornejo0105@gmail.com
                  </p>
                </div>
                <ExternalLink
                  class="w-4 h-4 text-ink-dim ml-auto opacity-0 group-hover:opacity-100 transition-opacity"
                />
              </a>

              <!-- Phone -->
              <a
                href="tel:+527711204655"
                class="flex items-center p-4 border border-border hover:border-accent transition-colors group no-underline"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 bg-accent/10 flex items-center justify-center"
                >
                  <Phone class="w-6 h-6 text-accent" />
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-ink">Teléfono / WhatsApp</h4>
                  <p class="text-sm text-ink-dim">+52 771 120 4655</p>
                </div>
                <ExternalLink
                  class="w-4 h-4 text-ink-dim ml-auto opacity-0 group-hover:opacity-100 transition-opacity"
                />
              </a>

              <!-- Location -->
              <div class="flex items-center p-4 border border-border">
                <div
                  class="flex-shrink-0 w-12 h-12 bg-accent-2/10 flex items-center justify-center"
                >
                  <MapPin class="w-6 h-6 text-accent-2" />
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-ink">Ubicación</h4>
                  <p class="text-sm text-ink-dim">Pachuca, Hidalgo, México</p>
                  <p class="text-xs text-ink-dim/70">
                    Trabajo remoto disponible
                  </p>
                </div>
              </div>
            </div>
          </Card>

          <!-- Availability -->
          <Card padding="md">
            <div class="mb-3">
              <Badge tone="success" dot>Disponible para nuevos proyectos</Badge>
            </div>
            <p class="text-sm text-ink-dim">
              Acepto proyectos de Angular, landing pages y consultoría técnica.
            </p>
          </Card>
        </div>

        <!-- Social Networks -->
        <div class="space-y-6">
          <Card padding="lg">
            <div class="flex items-center mb-6">
              <div
                class="w-10 h-10 bg-ink flex items-center justify-center mr-3"
              >
                <MessageCircle class="w-5 h-5 text-bg" />
              </div>
              <h3 class="text-xl font-semibold text-ink">
                Redes Profesionales
              </h3>
            </div>

            <!-- Social Links -->
            <div class="space-y-4">
              <!-- LinkedIn -->
              <a
                href="https://www.linkedin.com/in/adrian-de-jesus-garcia-cornejo-891066324"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center p-4 border border-border hover:border-accent transition-colors group no-underline"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 bg-accent/10 flex items-center justify-center"
                >
                  <Linkedin class="w-6 h-6 text-accent" />
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-ink">LinkedIn</h4>
                  <p class="text-sm text-ink-dim">
                    Perfil profesional y experiencia
                  </p>
                </div>
                <ExternalLink
                  class="w-4 h-4 text-ink-dim ml-auto opacity-0 group-hover:opacity-100 transition-opacity"
                />
              </a>

              <!-- GitHub -->
              <a
                href="https://github.com/Adrian-Cornejo"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center p-4 border border-border hover:border-accent transition-colors group no-underline"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 bg-surface border border-border flex items-center justify-center"
                >
                  <Github class="w-6 h-6 text-ink" />
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-ink">GitHub</h4>
                  <p class="text-sm text-ink-dim">Repositorios y proyectos</p>
                </div>
                <ExternalLink
                  class="w-4 h-4 text-ink-dim ml-auto opacity-0 group-hover:opacity-100 transition-opacity"
                />
              </a>
            </div>
          </Card>

          <!-- Call to Action -->
          <div class="bg-ink p-8 text-center">
            <h3 class="text-xl font-semibold text-bg mb-4">
              ¿Tienes un proyecto en mente?
            </h3>
            <p class="text-bg/70 mb-6 text-sm">
              Hablemos sobre cómo puedo ayudarte a crear una solución web
              excepcional.
            </p>
            <Button
              href="mailto:adrian.cornejo0105@gmail.com?subject=Nuevo%20Proyecto&body=Hola%20Adrián,%0D%0A%0D%0AMe%20interesa%20contactarte%20para..."
              variant="secondary"
              icon={Mail}
            >
              Enviar Email
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
