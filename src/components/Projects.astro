---
import { Github, ExternalLink, Code } from 'lucide-astro';
import { projects } from '../data/projects';
import Card from './ui/Card.astro';
import Badge from './ui/Badge.astro';
import Button from './ui/Button.astro';

const featuredProjects = projects.filter(project => project.featured);
---

<section id="projects" class="py-20 bg-bg">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-ink mb-4">
        Mis Proyectos
      </h2>
      <p class="text-xl text-ink-dim max-w-2xl mx-auto">
        Una selección de proyectos que demuestran mis habilidades en desarrollo
        frontend y full-stack con tecnologías modernas.
      </p>
    </div>

    <!-- Featured Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      {featuredProjects.map((project) => (
        <Card tilt padding="none" class="group overflow-hidden">
          <Fragment slot="media">
            <div class="relative overflow-hidden">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-64 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

              <!-- Project Links Overlay -->
              <div class="absolute top-4 right-4 flex space-x-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {project.githubUrl && (
                  <a
                    href={project.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="p-2 bg-surface hover:bg-bg shadow-lg transition-colors"
                    aria-label="Ver código en GitHub"
                  >
                    <Github class="w-5 h-5 text-ink" />
                  </a>
                )}
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="p-2 bg-surface hover:bg-bg shadow-lg transition-colors"
                    aria-label="Ver proyecto en vivo"
                  >
                    <ExternalLink class="w-5 h-5 text-ink" />
                  </a>
                )}
              </div>
            </div>
          </Fragment>

          <!-- Project Content -->
          <div class="p-6">
            <!-- Project Title -->
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <h3 class="text-2xl font-semibold text-ink">
                {project.title}
              </h3>
              {project.company && (
                <span class="text-sm text-ink-dim">({project.company})</span>
              )}
            </div>
            <div class="mb-3">
              {project.isPersonal ? (
                <Badge tone="accent" variant="outline">Proyecto Personal</Badge>
              ) : (
                <Badge tone="accent-2" variant="outline">Actual trabajo</Badge>
              )}
            </div>

            <!-- Project Description -->
            <p class="text-ink-dim mb-4 leading-relaxed">
              {project.description}
            </p>

            <!-- Long Description (expandable) -->
            <details class="mb-4">
              <summary class="cursor-pointer text-accent hover:text-accent/80 font-medium">
                Ver más detalles...
              </summary>
              <p class="text-ink-dim mt-2 leading-relaxed">
                {project.longDescription}
              </p>
            </details>

            <!-- Technologies -->
            <div class="mb-6">
              <h4 class="text-sm font-semibold text-ink mb-2 flex items-center">
                <Code class="w-4 h-4 mr-1" />
                Tecnologías utilizadas:
              </h4>
              <div class="flex flex-wrap gap-2">
                {project.technologies.map((tech) => (
                  <Badge variant="tag" tone="accent-2">{tech}</Badge>
                ))}
              </div>
            </div>

            <!-- Project Actions -->
            <div class="flex gap-3">
              {project.githubUrl && (
                <Button href={project.githubUrl} target="_blank" variant="outline" icon={Github} class="flex-1">
                  Código
                </Button>
              )}
              {project.liveUrl && (
                <Button href={project.liveUrl} target="_blank" variant="primary" icon={ExternalLink} class="flex-1">
                  Ver Proyecto
                </Button>
              )}
            </div>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>
