---
import {
  GraduationCap,
  Briefcase,
  Award,
  Code,
  Users,
  Target,
  Rocket,
  Database,
  Handshake,
  TrendingUp,
} from "lucide-astro";
import Card from "./ui/Card.astro";
import Badge from "./ui/Badge.astro";
---

<!-- src/components/About.astro -->
<section id="about" class="pt-64 pb-20 bg-bg">
  <div id="about-content" class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-ink mb-4">
        Sobre mí
      </h2>
      <p class="text-xl text-ink-dim max-w-2xl mx-auto">
        Desarrollador apasionado por crear soluciones tecnológicas que generen
        impacto positivo en la educación y la gestión empresarial.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      <!-- Personal Info & Photo -->
      <div class="space-y-8">
        <!-- Profile Image -->
        <div class="w-full max-w-md mx-auto">
          <img
            src="/images/adrian-avatar.png"
            alt="Adrián de Jesús García Cornejo"
            class="w-full border border-border shadow-lg"
          />
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-2 gap-4">
          <Card padding="md" class="text-center">
            <div class="font-mono text-3xl text-accent mb-2">2+</div>
            <div class="text-sm text-ink-dim">Años de experiencia</div>
          </Card>
          <Card padding="md" class="text-center">
            <div class="font-mono text-3xl text-accent mb-2">10+</div>
            <div class="text-sm text-ink-dim">Proyectos completados</div>
          </Card>
          <Card padding="md" class="text-center">
            <div class="font-mono text-3xl text-accent mb-2">3</div>
            <div class="text-sm text-ink-dim">Certificaciones CCNA</div>
          </Card>
          <Card padding="md" class="text-center">
            <div class="font-mono text-3xl text-accent mb-2">500+</div>
            <div class="text-sm text-ink-dim">Usuarios impactados</div>
          </Card>
        </div>

        <!-- Education -->
        <Card padding="lg">
          <h3 class="text-2xl font-semibold text-ink mb-6 flex items-center">
            <GraduationCap class="w-8 h-8 mr-2 text-accent" />
            Educación
          </h3>

          <div class="space-y-4">
            <!-- University -->
            <div class="border-l-2 border-accent pl-6">
              <h4 class="font-semibold text-ink">
                Ingeniería en Sistemas Computacionales
              </h4>
              <p class="text-ink-dim">
                Universidad Politécnica de Tulancingo
              </p>
              <p class="text-sm text-ink-dim/70">2021 - 2025 (Egresado)</p>
            </div>

            <!-- Technical Background -->
            <div class="border-l-2 border-accent-2 pl-6 py-1">
              <h4 class="font-semibold text-ink">Técnico en Construcción</h4>
              <p class="text-ink-dim">CBTis No. 199 "Emiliano Zapata"</p>
              <p class="text-sm text-ink-dim/70">2018 - 2021</p>
            </div>
          </div>
        </Card>

        <!-- Status terminal -->
        <Card padding="none" class="overflow-hidden">
          <div
            class="flex items-center gap-1.5 px-4 py-3 border-b border-border"
          >
            <span class="w-2.5 h-2.5 rounded-full bg-border"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-border"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-border"></span>
            <span class="ml-2 font-mono text-xs text-ink-dim">status.sh</span>
          </div>
          <pre
            id="status-terminal"
            class="font-mono text-sm leading-relaxed p-5 min-h-[220px] whitespace-pre-wrap text-ink-dim"></pre>
        </Card>
      </div>

      <!-- About Content -->
      <div class="space-y-8">
        <!-- Personal Story -->
        <Card padding="lg">
          <h3 class="text-2xl font-semibold text-ink mb-2 flex items-center">
            <Users class="w-6 h-6 mr-2 text-accent" />
            Mi Historia
          </h3>
          <div class="max-w-none">
            <p class="text-ink-dim leading-relaxed mb-4">
              Soy <strong class="text-ink">Adrián de Jesús García Cornejo</strong
              >, desarrollador Full-Stack especializado en <strong
                class="text-ink">Angular</strong
              > con experiencia sólida en desarrollo tanto frontend como backend.
              Mi formación en <strong class="text-ink"
                >Ingeniería en Sistemas Computacionales</strong
              > en la <strong class="text-ink"
                >Universidad Politécnica de Tulancingo</strong
              > me ha permitido desarrollar una visión integral del desarrollo de
              software.
            </p>
            <p class="text-ink-dim leading-relaxed">
              Actualmente trabajo en <strong class="text-ink"
                >Qrsof | Software web hosting & mail</strong
              >, donde he participado en el rediseño completo del sistema de
              telemetría TRACKSOF para gestión de flotas vehiculares. Mi
              experiencia abarca desde el desarrollo de componentes <strong
                class="text-ink">Angular 18</strong
              > reutilizables hasta la colaboración en APIs REST con <strong
                class="text-ink">Play Framework y Scala</strong
              >, permitiéndome abordar proyectos complejos de manera integral.
            </p>
            <p class="text-ink-dim leading-relaxed mt-4">
              En paralelo desarrollo <strong class="text-ink">ArriendaFacil</strong>,
              una plataforma SaaS propia para gestión de propiedades en renta en
              México, con backend en <strong class="text-ink"
                >Spring Boot 3</strong
              > y frontend en <strong class="text-ink">Angular 20</strong>. A
              partir de ahí construí <strong class="text-ink"
                >Postal MX API</strong
              >, un microservicio en <strong class="text-ink">NestJS</strong> que
              expone el catálogo postal mexicano (SEPOMEX) con autenticación por
              API Key, documentado con Swagger.
            </p>
          </div>
        </Card>

        <!-- Professional Experience -->
        <Card padding="lg">
          <h3 class="text-2xl font-semibold text-ink mb-6 flex items-center">
            <Briefcase class="w-6 h-6 mr-2 text-accent" />
            Experiencia Profesional
          </h3>

          <div class="space-y-6">
            <!-- Current Job -->
            <div class="flex items-start">
              <div
                class="flex-shrink-0 w-12 h-12 bg-accent/10 flex items-center justify-center"
              >
                <Code class="w-6 h-6 text-accent" />
              </div>
              <div class="ml-4 flex-1">
                <div class="flex items-center justify-between gap-2">
                  <h4 class="font-semibold text-ink">
                    Desarrollador Frontend Angular
                  </h4>
                  <Badge tone="success" dot>Actual</Badge>
                </div>
                <p class="text-accent font-medium">
                  Qrsof | Software web hosting & mail
                </p>
                <p class="text-sm text-ink-dim/70 mb-2">
                  Diciembre 2024 - Presente | Pachuca, Hidalgo
                </p>
                <ul class="text-ink-dim text-sm space-y-1">
                  <li>Rediseño completo del sistema de telemetría TRACKSOF</li>
                  <li>Desarrollo de componentes Angular 18 reutilizables</li>
                  <li>Colaboración en APIs REST con Play Framework y Scala</li>
                </ul>
              </div>
            </div>

            <!-- ArriendaFacil -->
            <div class="flex items-start">
              <div
                class="flex-shrink-0 w-12 h-12 bg-accent-2/10 flex items-center justify-center"
              >
                <Rocket class="w-6 h-6 text-accent-2" />
              </div>
              <div class="ml-4 flex-1">
                <div class="flex items-center justify-between gap-2">
                  <h4 class="font-semibold text-ink">
                    Desarrollador Full-Stack
                  </h4>
                  <Badge tone="accent-2" dot>En curso</Badge>
                </div>
                <p class="text-accent-2 font-medium">Proyecto ArriendaFacil</p>
                <p class="text-sm text-ink-dim/70 mb-2">
                  Noviembre 2025 - Presente
                </p>
                <ul class="text-ink-dim text-sm space-y-1">
                  <li>
                    Plataforma SaaS multi-tenant para gestión de propiedades en
                    renta en México
                  </li>
                  <li>Backend con Spring Boot 3, Java 17 y JWT/RBAC</li>
                  <li>
                    Frontend en Angular 20 con dashboard analítico y pagos en
                    tiempo real
                  </li>
                </ul>
              </div>
            </div>

            <!-- Postal MX API -->
            <div class="flex items-start">
              <div
                class="flex-shrink-0 w-12 h-12 bg-accent/10 flex items-center justify-center"
              >
                <Database class="w-6 h-6 text-accent" />
              </div>
              <div class="ml-4 flex-1">
                <h4 class="font-semibold text-ink">Desarrollador Backend</h4>
                <p class="text-accent font-medium">Proyecto Postal MX API</p>
                <p class="text-sm text-ink-dim/70 mb-2">
                  Mayo 2026 - Julio 2026
                </p>
                <ul class="text-ink-dim text-sm space-y-1">
                  <li>
                    API REST del catálogo postal mexicano (SEPOMEX) con
                    autenticación por API Key
                  </li>
                  <li>Construida con NestJS, PostgreSQL/Supabase y TypeORM</li>
                  <li>
                    Rate limiting, caché de 24h y documentación interactiva con
                    Swagger
                  </li>
                </ul>
              </div>
            </div>

            <!-- Project Experience -->
            <div class="flex items-start">
              <div
                class="flex-shrink-0 w-12 h-12 bg-accent-2/10 flex items-center justify-center"
              >
                <Target class="w-6 h-6 text-accent-2" />
              </div>
              <div class="ml-4 flex-1">
                <h4 class="font-semibold text-ink">
                  Desarrollador Full-Stack
                </h4>
                <p class="text-accent-2 font-medium">Proyecto SimulaScore</p>
                <p class="text-sm text-ink-dim/70 mb-2">
                  Enero 2024 - Noviembre 2024
                </p>
                <ul class="text-ink-dim text-sm space-y-1">
                  <li>Simulador educativo para +500 estudiantes potenciales</li>
                  <li>Frontend responsive con Angular y TailwindCSS</li>
                  <li>Backend con Play Framework y análisis de datos</li>
                </ul>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>

    <!-- Values & Approach -->
    <Card padding="lg" class="mt-12 max-w-5xl mx-auto">
      <h3
        class="text-2xl font-semibold text-ink mb-6 flex items-center justify-center"
      >
        <Award class="w-6 h-6 mr-2 text-accent" />
        Mi Enfoque
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-semibold text-ink mb-2 flex items-center">
            <Target class="w-5 h-5 mr-2 text-accent" />
            Orientado a Resultados
          </h4>
          <p class="text-ink-dim text-sm">
            Cada línea de código tiene un propósito claro: resolver problemas
            reales y mejorar la experiencia del usuario.
          </p>
        </div>
        <div>
          <h4 class="font-semibold text-ink mb-2 flex items-center">
            <Rocket class="w-5 h-5 mr-2 text-accent" />
            Innovación Constante
          </h4>
          <p class="text-ink-dim text-sm">
            Siempre al día con las últimas tecnologías, pero priorizando la
            estabilidad y escalabilidad.
          </p>
        </div>
        <div>
          <h4 class="font-semibold text-ink mb-2 flex items-center">
            <Handshake class="w-5 h-5 mr-2 text-accent" />
            Colaboración
          </h4>
          <p class="text-ink-dim text-sm">
            Trabajo en equipo efectivo, comunicación clara y liderazgo cuando es
            necesario.
          </p>
        </div>
        <div>
          <h4 class="font-semibold text-ink mb-2 flex items-center">
            <TrendingUp class="w-5 h-5 mr-2 text-accent" />
            Crecimiento Continuo
          </h4>
          <p class="text-ink-dim text-sm">
            Aprendizaje constante y mejora continua en cada proyecto que
            emprendo.
          </p>
        </div>
      </div>
    </Card>
  </div>
</section>

<script>
  async function runStatusTerminal() {
    const el = document.getElementById("status-terminal");
    if (!el) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const prompt =
      '<span class="text-accent">adrian@portfolio</span><span class="text-ink-dim">:~$</span> ';

    const steps = [
      {
        cmd: "whoami",
        output: "Adrián García — Full-Stack Developer\n\n",
      },
      {
        cmd: "status --now",
        output:
          '<span class="text-accent-2">●</span> ArriendaFacil     building\n' +
          '<span class="text-accent">●</span> Postal MX API     shipped\n' +
          '<span class="text-accent">●</span> TRACKSOF          in prod\n\n',
      },
    ];

    if (reduced) {
      let html = "";
      for (const step of steps) html += prompt + step.cmd + "\n" + step.output;
      html += prompt + '<span class="cursor-static">_</span>';
      el.innerHTML = html;
      return;
    }

    const wait = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));
    let html = "";

    for (const step of steps) {
      html += prompt;
      el.innerHTML = html;
      for (const char of step.cmd) {
        html += char;
        el.innerHTML = html;
        await wait(40);
      }
      html += "\n";
      el.innerHTML = html;
      await wait(250);
      html += step.output;
      el.innerHTML = html;
      await wait(500);
    }

    html += prompt + '<span class="cursor-blink">_</span>';
    el.innerHTML = html;
  }

  document.readyState === "loading"
    ? document.addEventListener("DOMContentLoaded", runStatusTerminal)
    : runStatusTerminal();
</script>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initAboutReveal() {
    const section = document.getElementById("about");
    const content = document.getElementById("about-content");
    if (!section || !content) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      content,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top bottom",
          toggleActions: "play none none reverse",
        },
      }
    );
  }

  document.readyState === "loading"
    ? document.addEventListener("DOMContentLoaded", initAboutReveal)
    : initAboutReveal();
</script>

<style>
  @keyframes cursor-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  .cursor-blink {
    animation: cursor-blink 1s step-start infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-blink {
      animation: none;
    }
  }
</style>
