---
import { Github, Linkedin, Mail, Phone, MapPin, Heart } from "lucide-astro";
---

<footer class="bg-[#1c1c1a] text-[#ece6d8]">
  <!-- Main Footer Content -->
  <div class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- About Section -->
      <div class="lg:col-span-2">
        <div class="flex items-center space-x-2 mb-4">
          <img
            src="/adrian-logo.svg"
            alt="Logo Adrián Cornejo"
            class="w-8 h-8 brightness-0 invert"
          />
          <h3 class="font-serif text-xl font-medium">Adrián García</h3>
        </div>
        <p class="text-[#a8a196] mb-6 max-w-md">
          Desarrollador Frontend especializado en Angular con pasión por crear
          experiencias web modernas y eficientes. Siempre aprendiendo y
          mejorando.
        </p>

        <!-- Social Links -->
        <div class="flex space-x-3">
          <a
            href="https://github.com/Adrian-Cornejo"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 border border-[#3a382f] hover:border-[#97a1c4] transition-colors"
            aria-label="GitHub"
          >
            <Github class="w-5 h-5" />
          </a>
          <a
            href="https://www.linkedin.com/in/adrian-de-jesus-garcia-cornejo-891066324"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 border border-[#3a382f] hover:border-[#97a1c4] transition-colors"
            aria-label="LinkedIn"
          >
            <Linkedin class="w-5 h-5" />
          </a>
          <a
            href="mailto:adrian.cornejo0105@gmail.com"
            class="p-2 border border-[#3a382f] hover:border-[#dba55a] transition-colors"
            aria-label="Email"
          >
            <Mail class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Enlaces rápidos</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="#about"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors"
            >
              Sobre mí
            </a>
          </li>
          <li>
            <a
              href="#skills"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors"
            >
              Habilidades
            </a>
          </li>
          <li>
            <a
              href="#projects"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors"
            >
              Proyectos
            </a>
          </li>
          <li>
            <a
              href="#contact"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors"
            >
              Contacto
            </a>
          </li>
          <li>
            <a
              href="/ADRIÁN DE JESÚS GARCÍA CORNEJO CV.pdf"
              target="_blank"
              download="CV-Adrian-Garcia-Cornejo.pdf"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors"
            >
              Descargar CV
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-center space-x-2">
            <Mail class="w-4 h-4 text-[#97a1c4]" />
            <a
              href="mailto:adrian.cornejo0105@gmail.com"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors text-sm"
            >
              adrian.cornejo0105@gmail.com
            </a>
          </li>
          <li class="flex items-center space-x-2">
            <Phone class="w-4 h-4 text-[#97a1c4]" />
            <a
              href="tel:+527712279111"
              class="text-[#a8a196] hover:text-[#ece6d8] transition-colors text-sm"
            >
              +52 771 227 9111
            </a>
          </li>
          <li class="flex items-center space-x-2">
            <MapPin class="w-4 h-4 text-[#dba55a]" />
            <span class="text-[#a8a196] text-sm">
              Pachuca, Hidalgo, México
            </span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[#3a382f]">
    <div class="container mx-auto px-6 py-4">
      <div
        class="flex flex-col md:flex-row justify-between items-center gap-2"
      >
        <p class="text-[#a8a196] text-sm">
          © 2025 Adrián de Jesús García Cornejo.
        </p>
        <a
          href="/aviso-de-privacidad"
          class="text-[#a8a196] hover:text-[#ece6d8] text-sm transition-colors"
        >
          Aviso de Privacidad
        </a>
        <p class="text-[#a8a196] text-sm flex items-center">
          Hecho con
          <Heart class="w-4 h-4 text-[#dba55a] mx-1" />
          usando Astro y TailwindCSS
        </p>
      </div>
    </div>
  </div>

  <!-- Back to Top Button -->
  <button
    id="back-to-top"
    class="fixed bottom-6 right-6 p-3 bg-[#97a1c4] text-[#1c1c1a] shadow-lg transition-all duration-300 opacity-0 invisible"
    aria-label="Volver arriba"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
    </svg>
  </button>
</footer>
<style>
  a {
    text-decoration: none;
  }
</style>

<script>
  // Back to top button
  const backToTopButton = document.getElementById("back-to-top");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 300) {
      backToTopButton?.classList.remove("opacity-0", "invisible");
      backToTopButton?.classList.add("opacity-100", "visible");
    } else {
      backToTopButton?.classList.add("opacity-0", "invisible");
      backToTopButton?.classList.remove("opacity-100", "visible");
    }
  });

  backToTopButton?.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });
</script>
