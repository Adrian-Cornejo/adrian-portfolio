---
import { Code, Download, Linkedin, Github, Mail } from "lucide-astro";
import Button from "./ui/Button.astro";
---

<section
  class="min-h-screen flex items-center justify-center bg-bg relative overflow-hidden pt-24 lg:pt-0"
>
  <div class="container mx-auto px-8 relative z-10 max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Contenido de texto -->
      <div class="space-y-8 flex flex-col justify-center">
        <!-- Nombre -->
        <div class="space-y-4">
          <div class="w-16 h-0.5 bg-accent-2"></div>
          <h1
            class="font-serif text-4xl md:text-5xl lg:text-6xl text-ink font-medium leading-tight"
          >
            Adrián de Jesús García Cornejo
          </h1>
          <p class="text-xl md:text-3xl text-ink-dim font-normal">
            Software Developer Full-Stack
          </p>
          <p class="text-lg md:text-xl text-ink-dim">
            Apasionado por crear soluciones innovadoras y eficientes.
          </p>
        </div>

        <!-- Botones -->
        <div class="flex flex-col lg:flex-row gap-4">
          <Button href="#projects" icon={Code}>Proyectos</Button>

          <Button
            href="/ADRIÁN DE JESÚS GARCÍA CORNEJO CV.pdf"
            target="_blank"
            download="CV-Adrian-Garcia-Cornejo.pdf"
            variant="outline"
            icon={Download}
          >
            Descargar CV
          </Button>

          <Button
            href="https://wa.me/7711204655"
            target="_blank"
            variant="outline"
            class="hover:border-green-600 hover:text-green-600"
          >
            <Fragment slot="icon">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.515z"
                ></path>
              </svg>
            </Fragment>
            Contáctame
          </Button>
        </div>

        <!-- Social Icons -->
        <div class="flex items-center gap-4">
          <a
            href="https://www.linkedin.com/in/adrian-de-jesus-garcia-cornejo-891066324"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 bg-surface border border-border hover:border-accent flex items-center justify-center transition-colors group"
          >
            <Linkedin class="w-5 h-5 text-ink-dim group-hover:text-accent" />
          </a>
          <a
            href="https://github.com/Adrian-Cornejo"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 bg-surface border border-border hover:border-accent flex items-center justify-center transition-colors group"
          >
            <Github class="w-5 h-5 text-ink-dim group-hover:text-ink" />
          </a>
          <a
            href="mailto:adrian.cornejo0105@gmail.com"
            class="w-11 h-11 bg-surface border border-border hover:border-accent flex items-center justify-center transition-colors group"
          >
            <Mail class="w-5 h-5 text-ink-dim group-hover:text-accent-2" />
          </a>
        </div>
      </div>

      <!-- Imagen -->
      <div class="flex align-center justify-center">
        <div class="relative w-72 sm:w-80 lg:w-96" data-tilt>
          <div class="absolute -inset-3 border border-accent-2/50"></div>
          <img
            src="/images/adrian-avatar.png"
            alt="Adrián García"
            class="relative w-full aspect-[4/5] object-cover shadow-2xl border border-border"
          />
        </div>
      </div>
    </div>
  </div>
</section>
