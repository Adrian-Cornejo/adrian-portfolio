---
export interface Props {
  as?: "div" | "article";
  href?: string;
  padding?: "none" | "sm" | "md" | "lg";
  tilt?: boolean;
  class?: string;
  [attr: string]: any;
}

const {
  as = "div",
  href,
  padding = "md",
  tilt = false,
  class: className = "",
  ...rest
} = Astro.props;

const paddings: Record<NonNullable<Props["padding"]>, string> = {
  none: "",
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
};

const Tag = href ? "a" : as;
const classes = `bg-surface border border-border ${paddings[padding]} ${
  href ? "block no-underline" : ""
} ${className}`;
---

<Tag href={href} class={classes} data-tilt={tilt ? true : undefined} {...rest}>
  <slot name="media" />
  <slot />
</Tag>
