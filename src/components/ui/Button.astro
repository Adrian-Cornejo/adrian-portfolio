---
export interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "icon";
  size?: "sm" | "md" | "lg";
  icon?: any;
  iconPosition?: "left" | "right";
  type?: "button" | "submit";
  target?: string;
  download?: string | boolean;
  ariaLabel?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  icon: Icon,
  iconPosition = "left",
  type = "button",
  target,
  download,
  ariaLabel,
  class: className = "",
} = Astro.props;

const sizes: Record<NonNullable<Props["size"]>, string> = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-sm",
  lg: "px-8 py-4 text-sm",
};

const variants: Record<NonNullable<Props["variant"]>, string> = {
  primary: "bg-accent text-bg hover:opacity-90",
  secondary: "bg-surface text-ink border border-border hover:border-accent",
  outline: "border border-border text-ink hover:border-accent hover:text-accent",
  icon: "p-3 bg-surface border border-border hover:border-accent",
};

const base =
  "inline-flex items-center justify-center gap-2 font-sans font-medium transition-colors duration-200 no-underline";

const sizeClass = variant === "icon" ? "" : sizes[size];
const classes = `${base} ${sizeClass} ${variants[variant]} ${className}`;

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  target={target}
  rel={target === "_blank" ? "noopener noreferrer" : undefined}
  download={download}
  aria-label={ariaLabel}
  class={classes}
>
  {iconPosition === "left" && (Icon ? <Icon class="w-5 h-5" /> : <slot name="icon" />)}
  <slot />
  {iconPosition === "right" && (Icon ? <Icon class="w-5 h-5" /> : <slot name="icon" />)}
</Tag>
