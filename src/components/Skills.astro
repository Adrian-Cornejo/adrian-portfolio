<!-- src/components/Skills.astro -->
---
import { Code, Database, Settings, BarChart3, Globe, Repeat, Lock } from 'lucide-astro';
import { skillCategories } from '../data/skills';
import Card from './ui/Card.astro';
---

<section id="skills" class="py-20 bg-surface">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-ink mb-4">
        Habilidades Técnicas
      </h2>
      <p class="text-xl text-ink-dim max-w-2xl mx-auto">
        Tecnologías y herramientas con las que trabajo diariamente para crear
        soluciones web modernas y eficientes.
      </p>
    </div>

    <!-- Skills Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {skillCategories.map((category, categoryIndex) => (
        <Card padding="md" class="fade-in-card" style={`animation-delay: ${categoryIndex * 80}ms`}>
          <!-- Category Header -->
          <div class="flex items-center mb-6">
            {category.name === 'Frontend' && <Code class="w-7 h-7 text-accent mr-3" />}
            {category.name === 'Backend' && <Settings class="w-7 h-7 text-accent-2 mr-3" />}
            {category.name === 'Bases de Datos' && <Database class="w-7 h-7 text-accent mr-3" />}
            {category.name === 'Herramientas' && <BarChart3 class="w-7 h-7 text-accent-2 mr-3" />}
            <h3 class="text-xl font-semibold text-ink">
              {category.name}
            </h3>
          </div>

          <!-- Skills List -->
          <div class="grid grid-cols-2 gap-3">
            {category.skills.map((skill) => (
              <div class="skill-tile bg-bg border border-border p-4 transition-colors duration-200 hover:border-accent hover:-translate-y-0.5">
                <div class="flex items-center justify-center mb-3">
                  <div class="w-11 h-11 bg-surface flex items-center justify-center">
                    <img
                      src={`/icons/${skill.name.toLowerCase().replace(/\s+/g, '-')}.svg`}
                      alt={`${skill.name} logo`}
                      class="w-7 h-7 object-contain"
                      loading="lazy"
                    />
                  </div>
                </div>
                <div class="text-center">
                  <h4 class="font-medium text-sm text-ink">
                    {skill.name}
                  </h4>
                </div>
              </div>
            ))}
          </div>
        </Card>
      ))}
    </div>

    <!-- Certifications Section -->
    <div class="mt-16">
      <h3 class="text-2xl font-semibold text-center text-ink mb-8">
        Certificaciones
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <Card padding="md" class="text-center">
          <div class="w-14 h-14 bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <Globe class="w-7 h-7 text-accent" />
          </div>
          <h4 class="font-semibold text-ink mb-2">
            CCNA: Introduction to Networks
          </h4>
          <p class="text-ink-dim text-sm">Cisco</p>
        </Card>

        <Card padding="md" class="text-center">
          <div class="w-14 h-14 bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <Repeat class="w-7 h-7 text-accent" />
          </div>
          <h4 class="font-semibold text-ink mb-2">
            CCNA: Switching & Routing
          </h4>
          <p class="text-ink-dim text-sm">Cisco</p>
        </Card>

        <Card padding="md" class="text-center">
          <div class="w-14 h-14 bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <Lock class="w-7 h-7 text-accent" />
          </div>
          <h4 class="font-semibold text-ink mb-2">
            CCNA: Redes Empresariales
          </h4>
          <p class="text-ink-dim text-sm">Cisco</p>
        </Card>

        <Card padding="md" class="text-center">
          <div class="w-14 h-14 bg-accent-2/10 flex items-center justify-center mx-auto mb-4">
            <Code class="w-7 h-7 text-accent-2" />
          </div>
          <h4 class="font-semibold text-ink mb-2">
            Python Programming
          </h4>
          <p class="text-ink-dim text-sm">Certificación Profesional</p>
        </Card>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in-card {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-in-card {
      animation: none;
      opacity: 1;
    }
  }
</style>
